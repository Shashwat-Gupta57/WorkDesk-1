generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  MEMBER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AuditAction {
  USER_CREATED
  USER_SUSPENDED
  USER_ACTIVATED
  USER_ROLE_CHANGED
  PASSWORD_CHANGED
  EMAIL_CHANGED
  PROFILE_UPDATED
  OWNERSHIP_TRANSFERRED
  ARTIFACT_VISIBILITY_CHANGED
  LIBRARY_SECTION_DELETED
  SET_DELETED
  SET_CREATED
  SET_UPDATED
  ARTIFACT_CREATED
  ARTIFACT_UPDATED
  ARTIFACT_DELETED
  ARTIFACT_VERSION_COMMITTED
  ARTIFACT_VERSION_RESTORED
}

enum ArtifactType {
  TEXT
  PDF
  DOCX
  PPTX
  IMAGE
  ZIP
  OTHER
}

enum Visibility {
  PRIVATE
  SHARED
  PUBLIC
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  name            String
  role            Role       @default(MEMBER)
  status          UserStatus @default(ACTIVE)
  themePreference String     @default("dark")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  auditLogsActed    AuditLog[] @relation("AuditActor")
  auditLogsTargeted AuditLog[] @relation("AuditTarget")
  sets              Set[]      @relation("SetOwner")
  artifacts         Artifact[] @relation("ArtifactOwner")
  authoredVersions  Version[]  @relation("VersionAuthor")

  @@index([email])
  @@index([role, status])
  @@map("users")
}

// ─────────────────────────────────────────────
// Set
// ─────────────────────────────────────────────

model Set {
  id        String    @id @default(uuid())
  name      String
  parentId  String?
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  owner    User       @relation("SetOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  parent   Set?       @relation("SetParent", fields: [parentId], references: [id], onDelete: Restrict)
  children Set[]      @relation("SetParent")
  artifacts Artifact[] @relation("ArtifactSet")

  @@index([parentId])
  @@index([ownerId])
  @@map("sets")
}

// ─────────────────────────────────────────────
// Artifact
// ─────────────────────────────────────────────

model Artifact {
  id          String       @id @default(uuid())
  title       String
  description String?
  tags        Json         @default("[]") // JSON string array
  type        ArtifactType
  visibility  Visibility   @default(PRIVATE)
  ownerId     String
  setId       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Relations
  owner    User      @relation("ArtifactOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  set      Set?      @relation("ArtifactSet", fields: [setId], references: [id], onDelete: Restrict)
  versions Version[] @relation("VersionArtifact")

  @@index([setId])
  @@index([ownerId])
  @@index([visibility])
  @@map("artifacts")
}

// ─────────────────────────────────────────────
// Version
// ─────────────────────────────────────────────

model Version {
  id            String   @id @default(uuid())
  artifactId    String
  versionNumber Int
  contentKey    String // Points to Cloudflare R2 object key (UUID-based)
  changeSummary String?
  authorId      String
  createdAt     DateTime @default(now())

  // Relations
  artifact Artifact @relation("VersionArtifact", fields: [artifactId], references: [id], onDelete: Cascade)
  author   User     @relation("VersionAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@unique([artifactId, versionNumber])
  @@index([artifactId])
  @@index([authorId])
  @@index([contentKey])
  @@map("versions")
}

// ─────────────────────────────────────────────
// AuditLog
// ─────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  actorId   String
  targetId  String?
  details   Json        @default("{}")
  createdAt DateTime    @default(now())

  // Relations
  actor  User  @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  target User? @relation("AuditTarget", fields: [targetId], references: [id], onDelete: Restrict)

  @@index([actorId, createdAt])
  @@index([targetId])
  @@map("audit_logs")
}
